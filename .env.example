# ==============================================================
# Plex Poster Downloader — Environment Configuration
# Copy this file to .env and fill in your values, then run:
#   docker compose up -d
# ==============================================================

# --------------------------------------------------------------
# CONTAINER / RUNTIME
# --------------------------------------------------------------

# Directory inside the container where config and history files are stored.
# Must match the target of the config volume in compose.yaml.
DATA_DIR=/app/config

# Custom string sent as the X-Plex-Client-Identifier header.
PLEXAPI_HEADER_IDENTIFIER=plex-poster-downloader

# Network interface and port the web server binds to.
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# Set to 1 to enable Flask debug mode (development only — never use in prod).
FLASK_DEBUG=0

# --------------------------------------------------------------
# PLEX CONNECTION  ← required
# --------------------------------------------------------------

# Base URL of your Plex Media Server (no trailing slash).
PLEX_URL=http://192.168.1.100:32400

# Plex authentication token.
# Find yours at: https://support.plex.tv/articles/204059436
PLEX_TOKEN=your-plex-token-here

# --------------------------------------------------------------
# DOWNLOAD SETTINGS
# --------------------------------------------------------------

# Absolute path where downloaded posters/backgrounds are saved.
# When using Kometa point this at the Kometa asset directory instead.
DOWNLOAD_BASE_DIR=/app/downloaded_posters

# How saved assets are named/organised on disk.
# ASSET_FOLDERS  — one sub-folder per item  (Kometa-compatible)
# PLEX_FOLDERS   — mirrors the Plex folder structure
ASSET_STYLE=ASSET_FOLDERS

# Comma-separated list of library names to skip entirely (manual and cron).
# Example: IGNORED_LIBRARIES=Music,Photos
IGNORED_LIBRARIES=

# --------------------------------------------------------------
# AUTHENTICATION
# --------------------------------------------------------------

# Set to true to disable the login screen.
# Only do this on a fully trusted private network.
AUTH_DISABLED=false

# --------------------------------------------------------------
# SCHEDULED (CRON) DOWNLOADS
# --------------------------------------------------------------

# Enable automatic scheduled downloads.
CRON_ENABLED=false

# Time to run the job in 24-hour HH:MM format.
CRON_TIME=03:00

# Which day(s) to run.
# Options: DAILY  MONDAY  TUESDAY  WEDNESDAY  THURSDAY  FRIDAY  SATURDAY  SUNDAY
CRON_DAY=DAILY

# Timezone for the schedule.  Use a tz database name (e.g. America/New_York,
# Europe/London) or "Local" to follow the system clock.
CRON_TZ=Local

# How the poster is chosen when multiple results are available.
# RANDOM — pick one at random   FIRST — always use the first result
CRON_MODE=RANDOM

# Preferred image provider for cron downloads.
# Options: tmdb  tvdb  gracenote  local  plex
CRON_PROVIDER=tmdb

# Also download background/art images during cron runs.
CRON_DOWNLOAD_BACKGROUNDS=false

# Comma-separated list of library names to include in cron runs.
# Leave empty to run against every library.
# Example: CRON_LIBRARIES=Movies,TV Shows
CRON_LIBRARIES=

# --------------------------------------------------------------
# LOGGING
# --------------------------------------------------------------

# Print detailed progress messages to the container log.
VERBOSE_LOGGING=false
